{
  "name": "@mieweb/ui",
  "version": "0.6.1",
  "description": "A themeable, accessible React component library built with Tailwind CSS",
  "author": "Medical Informatics Engineering, Inc.",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/mieweb/ui.git"
  },
  "homepage": "https://github.com/mieweb/ui#readme",
  "bugs": {
    "url": "https://github.com/mieweb/ui/issues"
  },
  "packageManager": "pnpm@10.29.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwindcss",
    "accessible",
    "themeable"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./components/*": {
      "import": {
        "types": "./dist/components/*/index.d.ts",
        "default": "./dist/components/*/index.js"
      },
      "require": {
        "types": "./dist/components/*/index.d.cts",
        "default": "./dist/components/*/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks/index.js"
      },
      "require": {
        "types": "./dist/hooks/index.d.cts",
        "default": "./dist/hooks/index.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      },
      "require": {
        "types": "./dist/utils/index.d.cts",
        "default": "./dist/utils/index.cjs"
      }
    },
    "./tailwind-preset": {
      "import": {
        "types": "./dist/tailwind-preset.d.ts",
        "default": "./dist/tailwind-preset.js"
      },
      "require": {
        "types": "./dist/tailwind-preset.d.cts",
        "default": "./dist/tailwind-preset.cjs"
      }
    },
    "./brands": {
      "import": {
        "types": "./dist/brands/index.d.ts",
        "default": "./dist/brands/index.js"
      },
      "require": {
        "types": "./dist/brands/index.d.cts",
        "default": "./dist/brands/index.cjs"
      }
    },
    "./brands/bluehive.css": "./dist/brands/bluehive.css",
    "./brands/ccme.css": "./dist/brands/ccme.css",
    "./brands/mieweb.css": "./dist/brands/mieweb.css",
    "./brands/ozwell.css": "./dist/brands/ozwell.css",
    "./brands/webchart.css": "./dist/brands/webchart.css",
    "./brands/enterprise-health.css": "./dist/brands/enterprise-health.css",
    "./brands/*": {
      "import": {
        "types": "./dist/brands/*.d.ts",
        "default": "./dist/brands/*.js"
      },
      "require": {
        "types": "./dist/brands/*.d.cts",
        "default": "./dist/brands/*.cjs"
      }
    },
    "./ag-grid": {
      "import": {
        "types": "./dist/ag-grid.d.ts",
        "default": "./dist/ag-grid.js"
      },
      "require": {
        "types": "./dist/ag-grid.d.cts",
        "default": "./dist/ag-grid.cjs"
      }
    },
    "./datavis": {
      "import": {
        "types": "./dist/datavis.d.ts",
        "default": "./dist/datavis.js"
      },
      "require": {
        "types": "./dist/datavis.d.cts",
        "default": "./dist/datavis.cjs"
      }
    },
    "./esheet": {
      "import": {
        "types": "./dist/esheet.d.ts",
        "default": "./dist/esheet.js"
      },
      "require": {
        "types": "./dist/esheet.d.cts",
        "default": "./dist/esheet.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./styles": "./dist/styles.css",
    "./markdown.css": "./dist/components/Markdown/styles.css",
    "./init.css": "./dist/styles/init.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "preinstall": "if [ -d .git ]; then git submodule update --init --recursive; fi",
    "dev": "tsup --watch",
    "prebuild": "npm run build:esheet",
    "build": "node --max-old-space-size=8192 ./node_modules/tsup/dist/cli-default.js && npm run build:css && npm run copy:brand-css && npm run copy:style-css && npm run copy:markdown-css",
    "build:esheet": "if [ ! -f packages/esheet/packages/core/dist/index.d.ts ] || [ ! -f packages/esheet/packages/renderer/src/index.output.css ]; then cd packages/esheet && npm ci && npx nx run-many --target=build --projects=@esheet/core,@esheet/fields,@esheet/adapters,@esheet/builder,@esheet/renderer --parallel; fi",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/base.css -o ./dist/styles.css --minify",
    "copy:brand-css": "cp src/brands/*.css dist/brands/ 2>/dev/null || true",
    "copy:style-css": "mkdir -p dist/styles && cp src/styles/init.css dist/styles/ 2>/dev/null || true",
    "copy:markdown-css": "mkdir -p dist/components/Markdown && cp src/components/Markdown/styles.css dist/components/Markdown/ 2>/dev/null || true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prestorybook": "npm run build:esheet",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "npm run build:esheet && storybook build",
    "test:coverage": "vitest run --coverage",
    "playwright:install": "playwright install --with-deps",
    "test:visual": "playwright test",
    "test:visual:ui": "playwright test --ui",
    "test:visual:debug": "playwright test --debug",
    "test:storybook": "test-storybook --url http://localhost:6006",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@esheet/builder": ">=0.0.2",
    "@esheet/renderer": ">=0.0.2",
    "ag-grid-community": ">=32.0.0",
    "ag-grid-react": ">=32.0.0",
    "datavis-ace": "=4.0.0-PRE.2",
    "js-yaml": ">=4.0.0",
    "mapbox-gl": ">=2.0.0",
    "mermaid": ">=10.0.0",
    "papaparse": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "wavesurfer.js": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@esheet/builder": {
      "optional": true
    },
    "@esheet/renderer": {
      "optional": true
    },
    "ag-grid-community": {
      "optional": true
    },
    "ag-grid-react": {
      "optional": true
    },
    "datavis-ace": {
      "optional": true
    },
    "js-yaml": {
      "optional": true
    },
    "mapbox-gl": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "papaparse": {
      "optional": true
    },
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "wavesurfer.js": {
      "optional": true
    }
  },
  "dependencies": {
    "@swc/helpers": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "google-libphonenumber": "^3.2.44",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.562.0",
    "luxon": "^3.7.2",
    "marked": "^17.0.3",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@esheet/adapters": "link:./packages/esheet/packages/adapters",
    "@esheet/builder": "link:./packages/esheet/packages/builder",
    "@esheet/core": "link:./packages/esheet/packages/core",
    "@esheet/fields": "link:./packages/esheet/packages/fields",
    "@esheet/renderer": "link:./packages/esheet/packages/renderer",
    "@eslint/js": "^9.39.3",
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.11",
    "@storybook/addon-docs": "^10.2.11",
    "@storybook/addon-links": "^10.2.11",
    "@storybook/react": "^10.2.11",
    "@storybook/react-vite": "^10.2.11",
    "@storybook/test-runner": "0.24.3",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.19.11",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "autoprefixer": "^10.4.24",
    "bootstrap": "^5.3.8",
    "codemirror": "^6.0.2",
    "d3": "^7.9.0",
    "d3-array": "^3.2.4",
    "d3-drag": "^3.0.0",
    "d3-flextree": "^2.1.2",
    "d3-hierarchy": "^3.1.2",
    "d3-org-chart": "^3.1.1",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-zoom": "^3.0.0",
    "@mieweb/datavis": "=0.0.0-PRE.2",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^10.2.11",
    "js-yaml": "^4.1.1",
    "jsdom": "^26.1.0",
    "mapbox-gl": "^3.18.1",
    "mermaid": "^11.12.3",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "1.100.0",
    "sortablejs": "^1.15.7",
    "storybook": "^10.2.11",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wavesurfer.js": "^7.12.1",
    "ychart": "file:./packages/ychart",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "datavis-ace": "=4.0.0-PRE.2",
      "@esheet/adapters": "link:./packages/esheet/packages/adapters",
      "@esheet/core": "link:./packages/esheet/packages/core",
      "@esheet/fields": "link:./packages/esheet/packages/fields"
    }
  }
}
